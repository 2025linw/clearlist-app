{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",

      "developmentClient": true,
      "distribution": "internal"
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "environment": "preview",

      "distribution": "internal"
    },
    "production": {
      "environment": "production",

      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
